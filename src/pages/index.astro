---
import PageLayout from "~/layouts/PageLayout.astro";
import PhotoHero from "~/components/sections/PhotoHero.astro";
import Statement from "~/components/sections/Statement.astro";
import FeaturedProjects from "~/components/sections/FeaturedProjects.astro";
import Stats from "~/components/sections/Stats.astro";
import Testimonial from "~/components/sections/Testimonial.astro";
import Contact from "~/components/sections/Contact.astro";
import { SITE } from "~/data/site";
import { getCollection } from "astro:content";
import hero from "~/assets/hero.jpg";

const featured = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title="Norven — Architecture of consequence."
  description="Norven is an architecture practice working on residences, cultural buildings, and landscapes across Northern Europe and beyond."
>
  <PhotoHero
    titlePlacement="overlay"
    eyebrow={`${SITE.name} · Est. ${SITE.founded}`}
    title={"Architecture<br>of consequence."}
    subtitle={SITE.description}
    src={hero}
    seed={2}
  />
  <Statement />
  <FeaturedProjects projects={featured} />
  <Stats />
  <Testimonial />
  <Contact />
</PageLayout>
