---
import PageLayout from "~/layouts/PageLayout.astro";
import Frame from "~/components/media/Frame.astro";
import Contact from "~/components/sections/Contact.astro";
import ProjectGallery from "~/components/sections/ProjectGallery.astro";
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import { withNeighbors } from "~/lib/projects/order";

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");
  return withNeighbors(projects).map(({ entry, prev, next }) => ({
    params: { slug: entry.id },
    props: { entry, prev, next },
  }));
}) satisfies GetStaticPaths;

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, year, type, location, area, status, brief, cover, gallery, testimonial } =
  entry.data;

const projectJsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: title,
  dateCreated: String(year),
  locationCreated: { "@type": "Place", name: location },
  creator: { "@type": "Organization", name: "Norven" },
  description: brief,
};
---

<PageLayout title={`${title} — Norven`} description={brief}>
  <article>
    <!-- HERO: full-bleed cover -->
    <Frame
      src={cover}
      alt={title}
      ratio="16/9"
      seed={0}
      parallax
      sizes="100vw"
      widths={[800, 1200, 1600, 2000]}
    />

    <!-- TITLE + META -->
    <section class="bg-bone py-16 lg:py-24">
      <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
        <p class="eyebrow text-brass mb-6" data-reveal>
          {type} · {year} · {status === "built" ? "Built" : "In Studio"}
        </p>
        <h1
          class="font-display text-ink leading-[0.92]"
          style="font-size: var(--text-display-1)"
          data-reveal
        >
          {title}
        </h1>
        <dl
          class="border-line-2 mt-12 grid grid-cols-2 gap-y-6 border-t pt-8 lg:grid-cols-3"
          data-reveal
        >
          <div>
            <dt class="eyebrow mb-1">Location</dt>
            <dd class="text-ink font-mono text-sm">{location}</dd>
          </div>
          <div>
            <dt class="eyebrow mb-1">Area</dt>
            <dd class="text-ink font-mono text-sm">{area}</dd>
          </div>
          <div>
            <dt class="eyebrow mb-1">Status</dt>
            <dd class="text-ink font-mono text-sm">{status === "built" ? "Built" : "In Studio"}</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- BRIEF -->
    <section class="bg-bone py-24 lg:py-32">
      <div class="mx-auto max-w-[1100px] px-6 lg:px-10">
        <p class="eyebrow mb-8" data-reveal>Brief</p>
        <p
          class="font-display text-ink leading-[1.18]"
          style="font-size: var(--text-display-3)"
          data-reveal
        >
          {brief}
        </p>
      </div>
    </section>

    <!-- BODY (markdown) -->
    <section class="bg-bone pb-24 lg:pb-32">
      <div class="mx-auto max-w-[760px] px-6 lg:px-10">
        <div
          class="prose-body text-ink-3 space-y-8 text-base leading-relaxed lg:text-lg"
          data-reveal
        >
          <Content />
        </div>
      </div>
    </section>

    <ProjectGallery gallery={gallery} />

    {
      testimonial && (
        <section class="bg-ink text-bone py-24 lg:py-32">
          <div class="mx-auto max-w-[1100px] px-6 lg:px-10">
            <blockquote
              class="font-display leading-[1.15]"
              style="font-size: var(--text-display-3)"
              data-reveal
            >
              "{testimonial.quote}"
            </blockquote>
            <p class="text-bone/70 mt-8 font-mono text-xs tracking-[0.16em] uppercase" data-reveal>
              {testimonial.author} · {testimonial.role}
            </p>
          </div>
        </section>
      )
    }

    <!-- PREV/NEXT -->
    <nav class="bg-bone border-line-2 border-t py-16" aria-label="Project navigation">
      <div class="mx-auto grid max-w-[1400px] grid-cols-2 gap-8 px-6 lg:px-10">
        {
          prev && (
            <a href={`/projects/${prev.id}`} class="group flex items-center gap-5">
              <div class="w-24 shrink-0 lg:w-32">
                <Frame src={prev.data.cover} alt={prev.data.title} ratio="4/3" seed={1} />
              </div>
              <div>
                <p class="text-ink-3 font-mono text-[10px] tracking-[0.18em] uppercase">
                  ← Previous
                </p>
                <p class="font-display text-ink group-hover:text-brass mt-2 text-2xl transition-colors">
                  {prev.data.title}
                </p>
              </div>
            </a>
          )
        }
        {
          next && (
            <a
              href={`/projects/${next.id}`}
              class="group flex items-center justify-end gap-5 text-right"
            >
              <div>
                <p class="text-ink-3 font-mono text-[10px] tracking-[0.18em] uppercase">Next →</p>
                <p class="font-display text-ink group-hover:text-brass mt-2 text-2xl transition-colors">
                  {next.data.title}
                </p>
              </div>
              <div class="w-24 shrink-0 lg:w-32">
                <Frame src={next.data.cover} alt={next.data.title} ratio="4/3" seed={2} />
              </div>
            </a>
          )
        }
      </div>
    </nav>
  </article>

  <Contact />

  <script type="application/ld+json" set:html={JSON.stringify(projectJsonLd)} is:inline />
</PageLayout>
