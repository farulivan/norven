---
import PageLayout from "~/layouts/PageLayout.astro";
import MonolithSilhouette from "~/components/three/MonolithSilhouette.astro";
import Contact from "~/components/sections/Contact.astro";
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry, i) => {
    const prev = sorted[(i - 1 + sorted.length) % sorted.length];
    const next = sorted[(i + 1) % sorted.length];
    return { params: { slug: entry.id }, props: { entry, prev, next } };
  });
}) satisfies GetStaticPaths;

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, year, type, location, area, status, brief, monolith } = entry.data;

const projectJsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: title,
  dateCreated: String(year),
  locationCreated: { "@type": "Place", name: location },
  creator: { "@type": "Organization", name: "Norven" },
  description: brief,
};
---

<PageLayout title={`${title} — Norven`} description={brief}>
  <article>
    <!-- HERO -->
    <section class="bg-bone relative min-h-[80vh] overflow-hidden" data-project-scene>
      <div
        class="mx-auto grid h-full max-w-[1400px] grid-cols-1 gap-12 px-6 pt-24 pb-20 lg:grid-cols-[1fr_1fr] lg:gap-16 lg:px-10 lg:pt-32 lg:pb-28"
      >
        <div class="flex flex-col justify-end">
          <p class="eyebrow text-brass mb-8" data-reveal>
            {type} · {year} · {status === "built" ? "Built" : "In Studio"}
          </p>
          <h1
            class="font-display text-ink leading-[0.92]"
            style="font-size: var(--text-display-1)"
            data-reveal
          >
            {title}
          </h1>
          <dl class="border-line-2 mt-12 grid grid-cols-2 gap-y-6 border-t pt-8 lg:grid-cols-3">
            <div>
              <dt class="eyebrow mb-1">Location</dt>
              <dd class="text-ink font-mono text-sm">{location}</dd>
            </div>
            <div>
              <dt class="eyebrow mb-1">Area</dt>
              <dd class="text-ink font-mono text-sm">{area}</dd>
            </div>
            <div>
              <dt class="eyebrow mb-1">Status</dt>
              <dd class="text-ink font-mono text-sm">
                {status === "built" ? "Built" : "In Studio"}
              </dd>
            </div>
          </dl>
        </div>
        <div class="relative flex items-center justify-center" data-monolith-mount>
          <MonolithSilhouette params={monolith} class="max-h-[600px]" />
          <canvas data-project-canvas class="absolute inset-0 block h-full w-full opacity-0"
          ></canvas>
        </div>
      </div>
    </section>

    <!-- BRIEF -->
    <section class="bg-bone py-24 lg:py-32">
      <div class="mx-auto max-w-[1100px] px-6 lg:px-10">
        <p class="eyebrow mb-8" data-reveal>Brief</p>
        <p
          class="font-display text-ink leading-[1.18]"
          style="font-size: var(--text-display-3)"
          data-reveal
        >
          {brief}
        </p>
      </div>
    </section>

    <!-- BODY (markdown) -->
    <section class="bg-bone pb-24 lg:pb-32">
      <div class="mx-auto max-w-[760px] px-6 lg:px-10">
        <div
          class="prose-body text-ink-3 space-y-8 text-base leading-relaxed lg:text-lg"
          data-reveal
        >
          <Content />
        </div>
      </div>
    </section>

    <!-- DRAWINGS (3 procedural svg schematics) -->
    <section class="bg-bone-2 py-24 lg:py-32">
      <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
        <p class="eyebrow mb-12" data-reveal>Drawings · selected</p>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          {/* Plan */}
          <figure class="bg-bone border-line-2 aspect-square border p-10" data-reveal>
            <svg viewBox="0 0 200 200" class="block h-full w-full" aria-label="Plan diagram">
              <rect
                x="20"
                y="20"
                width="160"
                height="160"
                fill="none"
                stroke="var(--color-ink)"
                stroke-width="0.5"></rect>
              <rect
                x="40"
                y="40"
                width="120"
                height="120"
                fill="none"
                stroke="var(--color-ink-3)"
                stroke-width="0.4"></rect>
              <circle
                cx="100"
                cy="100"
                r="20"
                fill="none"
                stroke="var(--color-brass)"
                stroke-width="0.8"></circle>
              {
                Array.from({ length: 7 }).map((_, i) => (
                  <line
                    x1={40 + i * 20}
                    y1="40"
                    x2={40 + i * 20}
                    y2="160"
                    stroke="var(--color-ink-3)"
                    stroke-width="0.2"
                    stroke-dasharray="2 3"
                  />
                ))
              }
            </svg>
            <figcaption class="text-ink-3 mt-6 font-mono text-[10px] tracking-[0.18em] uppercase">
              Plan · 1:200
            </figcaption>
          </figure>
          {/* Section */}
          <figure class="bg-bone border-line-2 aspect-square border p-10" data-reveal>
            <svg viewBox="0 0 200 200" class="block h-full w-full" aria-label="Section diagram">
              <line x1="20" y1="170" x2="180" y2="170" stroke="var(--color-ink)" stroke-width="0.8"
              ></line>
              {
                Array.from({ length: monolith.slabCount }).map((_, i) => {
                  const w = 140 * (1 - monolith.taper * (i / monolith.slabCount));
                  const x = (200 - w) / 2;
                  const y = 170 - (i + 1) * 14;
                  const isAccent = monolith.accentSlabs.includes(i);
                  return (
                    <rect
                      x={x}
                      y={y}
                      width={w}
                      height={12}
                      fill="none"
                      stroke={isAccent ? "var(--color-brass)" : "var(--color-ink)"}
                      stroke-width={isAccent ? "0.8" : "0.5"}
                    />
                  );
                })
              }
            </svg>
            <figcaption class="text-ink-3 mt-6 font-mono text-[10px] tracking-[0.18em] uppercase">
              Section · 1:200
            </figcaption>
          </figure>
          {/* Site */}
          <figure class="bg-bone border-line-2 aspect-square border p-10" data-reveal>
            <svg viewBox="0 0 200 200" class="block h-full w-full" aria-label="Site diagram">
              <circle
                cx="100"
                cy="100"
                r="85"
                fill="none"
                stroke="var(--color-ink-3)"
                stroke-width="0.3"
                stroke-dasharray="1 2"></circle>
              <circle
                cx="100"
                cy="100"
                r="60"
                fill="none"
                stroke="var(--color-ink-3)"
                stroke-width="0.3"></circle>
              <rect x="80" y="80" width="40" height="40" fill="var(--color-ink)"></rect>
              <line
                x1="10"
                y1="100"
                x2="190"
                y2="100"
                stroke="var(--color-ink-3)"
                stroke-width="0.3"
                stroke-dasharray="4 2"></line>
              <line
                x1="100"
                y1="10"
                x2="100"
                y2="190"
                stroke="var(--color-ink-3)"
                stroke-width="0.3"
                stroke-dasharray="4 2"></line>
              <text x="180" y="105" font-size="6" fill="var(--color-ink-3)" font-family="monospace"
                >N</text
              >
            </svg>
            <figcaption class="text-ink-3 mt-6 font-mono text-[10px] tracking-[0.18em] uppercase">
              Site · 1:1000
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- PREV/NEXT -->
    <nav class="bg-bone border-line-2 border-t py-16" aria-label="Project navigation">
      <div class="mx-auto grid max-w-[1400px] grid-cols-2 gap-8 px-6 lg:px-10">
        {
          prev && (
            <a href={`/projects/${prev.id}`} class="group block">
              <p class="text-ink-3 font-mono text-[10px] tracking-[0.18em] uppercase">← Previous</p>
              <p class="font-display text-ink group-hover:text-brass mt-2 text-2xl transition-colors">
                {prev.data.title}
              </p>
            </a>
          )
        }
        {
          next && (
            <a href={`/projects/${next.id}`} class="group block text-right">
              <p class="text-ink-3 font-mono text-[10px] tracking-[0.18em] uppercase">Next →</p>
              <p class="font-display text-ink group-hover:text-brass mt-2 text-2xl transition-colors">
                {next.data.title}
              </p>
            </a>
          )
        }
      </div>
    </nav>
  </article>

  <Contact />

  <script type="application/ld+json" set:html={JSON.stringify(projectJsonLd)} is:inline />
</PageLayout>
