---
import { SERVICES } from "~/data/services";

const icons: Record<string, string> = {
  compass: `<circle cx="24" cy="24" r="22" /><line x1="24" y1="6" x2="24" y2="14" /><line x1="24" y1="34" x2="24" y2="42" /><line x1="6" y1="24" x2="14" y2="24" /><line x1="34" y1="24" x2="42" y2="24" /><circle cx="24" cy="24" r="2" fill="currentColor" />`,
  rule: `<line x1="6" y1="8" x2="42" y2="8" /><line x1="6" y1="40" x2="42" y2="40" /><line x1="6" y1="8" x2="6" y2="14" /><line x1="14" y1="8" x2="14" y2="12" /><line x1="22" y1="8" x2="22" y2="14" /><line x1="30" y1="8" x2="30" y2="12" /><line x1="38" y1="8" x2="38" y2="14" /><line x1="6" y1="40" x2="6" y2="34" /><line x1="14" y1="40" x2="14" y2="36" /><line x1="22" y1="40" x2="22" y2="34" /><line x1="30" y1="40" x2="30" y2="36" /><line x1="38" y1="40" x2="38" y2="34" />`,
  leaf: `<path d="M8 40 C 8 20, 28 8, 40 8 C 40 28, 28 40, 8 40 Z" /><line x1="8" y1="40" x2="40" y2="8" />`,
  book: `<rect x="8" y="8" width="32" height="32" /><line x1="24" y1="8" x2="24" y2="40" /><line x1="14" y1="16" x2="20" y2="16" /><line x1="14" y1="22" x2="20" y2="22" /><line x1="14" y1="28" x2="20" y2="28" /><line x1="28" y1="16" x2="34" y2="16" /><line x1="28" y1="22" x2="34" y2="22" /><line x1="28" y1="28" x2="34" y2="28" />`,
};
---

<section id="practice" class="bg-bone py-32 lg:py-44">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <div class="mb-20 grid grid-cols-1 gap-10 lg:grid-cols-[1fr_2fr] lg:gap-16">
      <div>
        <p class="eyebrow mb-6" data-reveal>Practice</p>
        <h2
          class="font-display text-ink leading-[0.95]"
          style="font-size: var(--text-display-2)"
          data-reveal
        >
          Four arms<br />
          <span class="text-ink-3">of a single discipline.</span>
        </h2>
      </div>
      <p class="text-ink-3 self-end text-base leading-relaxed lg:text-lg" data-reveal>
        We do not separate architecture, interiors, and landscape into distinct contracts. One team,
        one fee, one set of drawings — the only honest way to make a building hold together.
      </p>
    </div>

    <div class="bg-line-2 grid grid-cols-1 gap-px sm:grid-cols-2">
      {
        SERVICES.map((s, i) => (
          <article class="bg-bone group relative p-10 lg:p-12" data-reveal>
            <div class="mb-10 flex items-start justify-between">
              <p class="text-ink-3 font-mono text-xs tracking-[0.18em] uppercase">
                {String(i + 1).padStart(2, "0")}
              </p>
              <div class="text-ink h-12 w-12 transition-transform duration-500 group-hover:rotate-180">
                <svg
                  viewBox="0 0 48 48"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  set:html={icons[s.iconKey]}
                />
              </div>
            </div>
            <h3 class="font-display text-ink mb-4 text-2xl lg:text-3xl">{s.title}</h3>
            <p class="text-ink-3 text-sm leading-relaxed">{s.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
