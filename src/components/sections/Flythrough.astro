---
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const cardTints: string[] = [
  "from-[#D9D2C3] to-[#B8AE9A]",
  "from-[#2A2823] to-[#15140F]",
  "from-[#E9E4D7] to-[#B58A50]",
  "from-[#D8D2C2] to-[#8B8678]",
  "from-[#15140F] to-[#2A2823]",
];
---

<section id="flythrough" class="bg-bone py-24 lg:py-32">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <div class="relative min-h-screen" style="perspective: 1400px; perspective-origin: 50% 50%;">
      <div
        class="absolute inset-0 flex items-center justify-center"
        style="transform-style: preserve-3d;"
      >
        {
          projects.map((p, i) => {
            const isDark = i === 1 || i === 4;
            const tint = cardTints[i] ?? cardTints[0];
            return (
              <a
                href={`/projects/${p.id}`}
                class:list={[
                  "border-line/40 absolute h-[480px] w-[360px] overflow-hidden border bg-linear-to-br shadow-[0_8px_40px_rgba(17,17,16,0.12)] transition-transform hover:scale-105",
                  tint,
                ]}
                style={`z-index: ${100 - i};`}
                data-card-idx={i}
              >
                <div class="relative flex h-full flex-col justify-between p-6">
                  <div
                    class:list={[
                      "font-mono text-[10px] tracking-[0.18em] uppercase",
                      isDark ? "text-bone/70" : "text-ink-3",
                    ]}
                  >
                    <span>{p.data.status === "built" ? "Built" : "In Studio"}</span>
                    <span class="mx-2">·</span>
                    <span>{p.data.year}</span>
                  </div>
                  <div>
                    <p
                      class:list={[
                        "mb-2 font-mono text-[10px] tracking-[0.18em] uppercase",
                        isDark ? "text-bone/70" : "text-ink-3",
                      ]}
                    >
                      {p.data.type} · {p.data.location}
                    </p>
                    <h3
                      class:list={[
                        "font-display leading-[0.95]",
                        isDark ? "text-bone" : "text-ink",
                      ]}
                      style="font-size: clamp(1.75rem, 3vw, 2.5rem)"
                    >
                      {p.data.title}
                    </h3>
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>

    <p
      class="text-ink-3 mt-16 text-center font-mono text-[11px] tracking-[0.18em] uppercase"
      data-reveal
    >
      → <a href="/projects" class="hover:text-ink border-b border-current pb-1 transition-colors"
        >View all projects</a
      >
    </p>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { scrollEffect } from "~/lib/motion";

  scrollEffect((ctx) => {
    const section = document.getElementById("flythrough");
    if (!section) return;
    const cards = gsap.utils.toArray<HTMLElement>("[data-card-idx]");
    if (cards.length === 0) return;
    if (ctx.reduced) {
      // leave cards in DOM order, fan them out subtly so all are visible
      cards.forEach((card, i) => {
        gsap.set(card, {
          x: (i - (cards.length - 1) / 2) * 40,
          y: i * 8,
          rotateY: i % 2 === 0 ? 6 : -6,
          opacity: 1,
        });
      });
      return;
    }

    const total = cards.length;
    const stride = 900;

    // initial state: all cards stacked behind the camera
    cards.forEach((card, i) => {
      gsap.set(card, {
        x: 0,
        translateZ: -i * stride,
        rotateY: i % 2 === 0 ? 12 : -12,
        opacity: 0,
        force3D: true,
      });
    });

    const trigger = ScrollTrigger.create({
      trigger: section,
      start: "top top",
      end: `+=${total * 100}%`,
      pin: true,
      scrub: 0.5,
      onUpdate: (self) => {
        const progress = self.progress; // 0..1
        cards.forEach((card, i) => {
          const startZ = -i * stride;
          const endZ = (total - i) * stride;
          const z = startZ + (endZ - startZ) * progress;
          const opacity = Math.max(0, 1 - Math.abs(z) / 2200);
          const xOffset = (i % 2 === 0 ? 1 : -1) * Math.max(0, 1 - Math.abs(z) / 1000) * 60;
          gsap.set(card, { translateZ: z, opacity, x: xOffset });
        });
      },
    });

    return () => trigger.kill();
  });
</script>
