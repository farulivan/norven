---
import { LAYERS } from "~/data/layers";
---

<section id="layers" class="bg-bone py-32 lg:py-44">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <div class="mb-20 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="eyebrow mb-6" data-reveal>A signature project, in section</p>
        <h2
          class="font-display text-ink leading-[0.95]"
          style="font-size: var(--text-display-2)"
          data-reveal
        >
          Nord-Strata Tower<br />
          <span class="text-ink-3">— from sub-grade to crown.</span>
        </h2>
      </div>
      <p class="text-ink-3 max-w-md text-sm leading-relaxed" data-reveal>
        A vertical archive for the Nordic Council. Eight programmatic plates stacked around a
        central daylight void, each carrying one century of material culture.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[280px_1fr] lg:gap-16">
      <aside class="font-mono text-xs">
        <ol class="space-y-6">
          {
            LAYERS.map((p) => (
              <li class="border-line-2 border-l pl-4" data-reveal>
                <p class="text-ink-3 mb-1 text-[10px] tracking-[0.18em] uppercase">
                  {p.code} · {p.elevation}
                </p>
                <p class="text-ink text-sm font-medium">{p.name}</p>
                <p class="text-ink-3 mt-2 text-xs leading-relaxed">{p.title}</p>
              </li>
            ))
          }
        </ol>
      </aside>

      <div
        class="relative min-h-[600px] overflow-hidden lg:min-h-[760px]"
        style="perspective: 2400px; perspective-origin: 50% 42%;"
      >
        <div
          id="layers-tower"
          class="absolute top-1/2 left-1/2 flex flex-col items-center"
          style="transform: translate(-50%, -50%) scale(0.6) rotateX(58deg) rotateZ(-32deg); transform-style: preserve-3d;"
        >
          {
            LAYERS.map((p, i) => {
              const z = (LAYERS.length - 1 - i) * 42;
              const isAccent = i === 0 || i === 3 || i === LAYERS.length - 1;
              return (
                <div
                  class="border-line bg-bone relative mb-1 flex h-[200px] w-[260px] items-center justify-center border shadow-[0_1px_0_rgba(17,17,16,0.08)]"
                  style={`transform: translateZ(${z}px); background-color: ${isAccent ? "var(--color-bone-2)" : "var(--color-bone)"};`}
                  data-plate-idx={i}
                >
                  <div class="text-center">
                    <p class="text-ink-3 font-mono text-[10px] tracking-[0.18em] uppercase">
                      {p.code}
                    </p>
                    <p class="font-display text-ink mt-1 text-xl">{p.name}</p>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { scrollEffect } from "~/lib/motion";

  scrollEffect((ctx) => {
    const section = document.getElementById("layers");
    const tower = document.getElementById("layers-tower");
    if (!section || !tower) return;
    const plates = gsap.utils.toArray<HTMLElement>("[data-plate-idx]");
    if (plates.length === 0) return;
    if (ctx.reduced) return; // leave static layout in place

    gsap.set(plates, { opacity: 0, y: 40 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",
        end: "+=180%",
        pin: true,
        scrub: 0.4,
      },
    });

    tl.to(tower, { rotationX: 40, rotationZ: -14, duration: 1, ease: "none" }, 0);
    plates.forEach((plate, i) => {
      tl.to(plate, { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" }, i * 0.25);
    });

    return () => {
      tl.scrollTrigger?.kill();
      tl.kill();
    };
  });
</script>
