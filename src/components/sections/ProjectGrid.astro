---
import Frame from "~/components/media/Frame.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  projects: CollectionEntry<"projects">[];
}
const { projects } = Astro.props;
const sorted = [...projects].sort((a, b) => a.data.order - b.data.order);
---

<section class="bg-bone py-16 lg:py-24">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
    <h2 class="sr-only">Selected projects</h2>
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3 lg:gap-12">
      {
        sorted.map((p, i) => (
          <a href={`/projects/${p.id}`} class="group block" data-reveal>
            <Frame
              src={p.data.cover}
              alt={p.data.title}
              ratio="4/3"
              seed={i}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
            />
            <p class="eyebrow text-brass mt-5">
              {p.data.type} · {p.data.year}
            </p>
            <h3 class="font-display text-ink group-hover:text-brass mt-1 text-2xl transition-colors">
              {p.data.title}
            </h3>
            <p class="text-ink-3 mt-1 font-mono text-xs tracking-[0.14em] uppercase">
              {p.data.location}
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>
