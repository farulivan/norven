---
import Figure from "~/components/media/Figure.astro";
import type { ImageMetadata } from "astro";

interface GalleryItem {
  src: ImageMetadata;
  alt: string;
  caption?: string | undefined;
}
interface Props {
  gallery: GalleryItem[];
}
const { gallery } = Astro.props;
---

{
  gallery.length > 0 && (
    <section class="bg-bone py-24 lg:py-32">
      <div class="mx-auto max-w-[1400px] px-6 lg:px-10">
        <p class="eyebrow mb-12" data-reveal>
          Photographs
        </p>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          {gallery.map((item) => (
            <div data-reveal>
              <Figure src={item.src} alt={item.alt} caption={item.caption} />
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
