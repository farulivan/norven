---
interface MonolithParams {
  slabCount: number;
  heightUnit: number;
  taper: number;
  rotation: number;
  accentSlabs: readonly number[];
}
interface Props {
  params: MonolithParams;
  class?: string;
}
const { params, class: className = "" } = Astro.props;
const { slabCount, taper, accentSlabs } = params;

const widthBase = 130;
const slabHeight = 18;
const gap = 3;
const totalHeight = slabCount * (slabHeight + gap);
const viewBoxHeight = 360;
const viewBoxWidth = 200;
const baseY = (viewBoxHeight - totalHeight) / 2 + totalHeight;
---

<svg
  viewBox={`0 0 ${viewBoxWidth} ${viewBoxHeight}`}
  class:list={["block h-full w-auto", className]}
  aria-hidden="true"
>
  {
    Array.from({ length: slabCount }).map((_, i) => {
      const w = widthBase * (1 - taper * (i / slabCount));
      const x = (viewBoxWidth - w) / 2;
      const y = baseY - (i + 1) * (slabHeight + gap);
      const isAccent = accentSlabs.includes(i);
      return (
        <rect
          x={x}
          y={y}
          width={w}
          height={slabHeight}
          fill={isAccent ? "var(--color-brass)" : "var(--color-ink)"}
          opacity={isAccent ? 0.88 : 0.95}
        />
      );
    })
  }
  <line
    x1={viewBoxWidth * 0.1}
    y1={baseY + 4}
    x2={viewBoxWidth * 0.9}
    y2={baseY + 4}
    stroke="var(--color-ink)"
    stroke-width="0.4"></line>
</svg>
