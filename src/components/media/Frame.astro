---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { placeholderGradient } from "~/lib/media/placeholder";

interface Props {
  src?: ImageMetadata | undefined;
  alt: string;
  caption?: string | undefined;
  class?: string | undefined;
  ratio?: string; // aspect-ratio, e.g. "4/3", "3/4", "16/9"
  seed?: number; // varies the placeholder gradient
  parallax?: boolean; // gentle vertical drift (handled by the motion runtime)
  widths?: number[];
  sizes?: string;
}
const {
  src,
  alt,
  caption,
  class: className,
  ratio = "4/3",
  seed = 0,
  parallax = false,
  widths = [400, 800, 1200, 1600],
  sizes = "(min-width: 1024px) 50vw, 100vw",
} = Astro.props;
---

<figure class:list={["m-0", className]}>
  <div class="bg-bone-2 relative overflow-hidden" style={`aspect-ratio: ${ratio};`}>
    <div
      class:list={["absolute inset-0", parallax && "-top-10% h-[120%]"]}
      data-parallax={parallax ? "8" : undefined}
    >
      {
        src ? (
          <Image
            src={src}
            alt={alt}
            widths={widths}
            sizes={sizes}
            class="block h-full w-full object-cover"
          />
        ) : (
          <div
            class="h-full w-full"
            style={`background: ${placeholderGradient(seed)};`}
            role="img"
            aria-label={alt}
          >
            {import.meta.env.DEV && (
              <span class="text-ink/70 absolute bottom-2 left-2 font-mono text-[10px] tracking-[0.14em] uppercase">
                TODO: photo — {alt}
              </span>
            )}
          </div>
        )
      }
    </div>
  </div>
  {
    caption && (
      <figcaption class="text-ink-3 mt-3 font-mono text-[10px] tracking-[0.18em] uppercase">
        {caption}
      </figcaption>
    )
  }
</figure>
