---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string | undefined;
  class?: string;
  widths?: number[];
  sizes?: string;
}
const {
  src,
  alt,
  caption,
  class: className,
  widths = [400, 800, 1200],
  sizes = "(min-width: 1024px) 50vw, 100vw",
} = Astro.props;
---

<figure class:list={["m-0", className]}>
  <Image src={src} alt={alt} widths={widths} sizes={sizes} class="block h-auto w-full" />
  {
    caption && (
      <figcaption class="text-ink-3 mt-3 font-mono text-[10px] tracking-[0.18em] uppercase">
        {caption}
      </figcaption>
    )
  }
</figure>
