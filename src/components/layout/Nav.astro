---
import { SITE } from "~/data/site";
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(href + "/");
---

<header class="bg-bone/80 border-line-2 sticky top-0 z-40 border-b backdrop-blur-md" data-nav>
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-6 lg:px-10">
    <a href="/" class="font-display text-ink text-2xl leading-none tracking-tight"> Norven </a>

    <nav class="hidden md:flex md:items-center md:gap-10" aria-label="Primary">
      {
        SITE.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "font-mono text-[11px] tracking-[0.18em] uppercase transition-colors",
              isActive(item.href)
                ? "text-ink border-ink border-b pb-1"
                : "text-ink-3 hover:text-ink",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="/contact"
      class="border-ink text-ink hover:bg-ink hover:text-bone hidden border px-4 py-2 font-mono text-[11px] tracking-[0.18em] uppercase transition-colors md:inline-block"
    >
      Submit a brief
    </a>

    <span class="block h-10 w-10 md:hidden" aria-hidden="true"></span>
  </div>
</header>

<button
  type="button"
  id="nav-button"
  aria-expanded="false"
  aria-controls="mobile-menu"
  aria-label="Open menu"
  class:list={[
    "text-ink fixed top-3 right-4 z-80 flex h-10 w-10 cursor-pointer flex-col items-center justify-center gap-1.5 md:hidden",
    "aria-expanded:[&>span:nth-child(1)]:translate-y-[7px] aria-expanded:[&>span:nth-child(1)]:rotate-45",
    "aria-expanded:[&>span:nth-child(2)]:opacity-0",
    "aria-expanded:[&>span:nth-child(3)]:translate-y-[-7px] aria-expanded:[&>span:nth-child(3)]:-rotate-45",
  ]}
>
  <span class="bg-ink h-px w-6 transition-all duration-300"></span>
  <span class="bg-ink h-px w-6 transition-all duration-300"></span>
  <span class="bg-ink h-px w-6 transition-all duration-300"></span>
</button>

<div
  id="mobile-menu"
  class="bg-bone invisible fixed inset-0 z-70 flex flex-col items-center justify-center gap-10 opacity-0 transition-opacity duration-300 data-open:visible data-open:opacity-100 md:hidden"
>
  {
    SITE.nav.map((item) => (
      <a
        href={item.href}
        class:list={[
          "font-display text-5xl transition-colors",
          isActive(item.href) ? "text-ink" : "text-ink-3 hover:text-ink",
        ]}
      >
        {item.label}
      </a>
    ))
  }
  <a
    href="/contact"
    class="border-ink text-ink mt-8 border px-6 py-3 font-mono text-xs tracking-[0.18em] uppercase"
  >
    Submit a brief
  </a>
</div>

<style is:global>
  html.nav-open {
    overflow: hidden;
  }
</style>

<script>
  function setupNav() {
    const button = document.getElementById("nav-button");
    const menu = document.getElementById("mobile-menu");
    if (!button || !menu) return;

    // Clear any stale scroll lock after a navigation; the swapped-in DOM starts closed.
    document.documentElement.classList.remove("nav-open");

    const setOpen = (open: boolean) => {
      button.setAttribute("aria-expanded", String(open));
      button.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      if (open) menu.setAttribute("data-open", "");
      else menu.removeAttribute("data-open");
      document.documentElement.classList.toggle("nav-open", open);
    };

    button.addEventListener("click", () => {
      const wasOpen = button.getAttribute("aria-expanded") === "true";
      setOpen(!wasOpen);
      if (wasOpen) {
        button.focus();
      } else {
        const firstLink = menu.querySelector("a");
        if (firstLink instanceof HTMLElement) firstLink.focus();
      }
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });
  }

  function onKeydown(event: KeyboardEvent) {
    if (event.key !== "Escape") return;
    const button = document.getElementById("nav-button");
    const menu = document.getElementById("mobile-menu");
    if (!button || !menu || button.getAttribute("aria-expanded") !== "true") return;
    button.setAttribute("aria-expanded", "false");
    button.setAttribute("aria-label", "Open menu");
    menu.removeAttribute("data-open");
    document.documentElement.classList.remove("nav-open");
    button.focus();
  }

  document.addEventListener("keydown", onKeydown);
  document.addEventListener("astro:page-load", setupNav);
</script>
