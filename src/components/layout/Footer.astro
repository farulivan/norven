---
import { SITE } from "~/data/site";
const year = new Date().getFullYear();
---

<footer class="bg-bone text-ink border-line-2 border-t">
  <div class="mx-auto max-w-[1400px] px-6 py-20 lg:px-10 lg:py-28">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <p class="eyebrow mb-6">Studios</p>
        <ul class="space-y-5">
          {
            SITE.studios.map((studio) => (
              <li class="font-sans text-sm">
                <p class="text-ink mb-1 font-medium">{studio.city}</p>
                <p class="text-ink-3 leading-relaxed">
                  {studio.address}
                  <br />
                  {studio.country}
                </p>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">Work</p>
        <ul class="space-y-3 font-sans text-sm">
          <li>
            <a href="/projects" class="text-ink-3 hover:text-ink transition-colors"
              >Selected projects</a
            >
          </li>
          <li><a href="/studio" class="text-ink-3 hover:text-ink transition-colors">Studio</a></li>
          <li>
            <a href="/#practice" class="text-ink-3 hover:text-ink transition-colors"
              >Practice areas</a
            >
          </li>
          <li>
            <a href="/#process" class="text-ink-3 hover:text-ink transition-colors">Process</a>
          </li>
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">Reach</p>
        <ul class="space-y-3 font-sans text-sm">
          <li>
            <a href={`mailto:${SITE.email}`} class="text-ink-3 hover:text-ink transition-colors">
              {SITE.email}
            </a>
          </li>
          <li>
            <a
              href={`tel:${SITE.phone.replaceAll(" ", "")}`}
              class="text-ink-3 hover:text-ink transition-colors"
            >
              {SITE.phone}
            </a>
          </li>
          <li>
            <a
              href={SITE.social.instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-3 hover:text-ink transition-colors"
            >
              Instagram · {SITE.social.instagram.handle}
            </a>
          </li>
          <li>
            <a
              href={SITE.social.linkedin.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-3 hover:text-ink transition-colors"
            >
              LinkedIn · {SITE.social.linkedin.handle}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">Brief</p>
        <p class="text-ink-3 mb-6 font-sans text-sm leading-relaxed">
          Bring us a site, a story, a single hour of light.
        </p>
        <a
          href="/contact"
          class="border-ink text-ink hover:bg-ink hover:text-bone inline-block border px-5 py-3 font-mono text-[11px] tracking-[0.18em] uppercase transition-colors"
        >
          Submit a brief
        </a>
      </div>
    </div>

    <div
      class="border-line-2 mt-16 flex flex-col gap-4 border-t pt-8 md:flex-row md:items-center md:justify-between"
    >
      <p class="text-ink-3 font-mono text-[11px] tracking-[0.14em]">
        © {year}
        {SITE.name} · Established MMIX
      </p>
      <p class="text-ink-3 font-mono text-[11px] tracking-[0.14em]">
        Built in Astro · Oslo · Lisbon · Kyoto
      </p>
    </div>
  </div>
</footer>
